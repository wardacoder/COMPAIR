# ============================================
# COMPAIR - Environment Variables Template
# ============================================
# Copy this file to .env and update with your values
# cp .env.example .env

# ============================================
# API Keys (REQUIRED)
# ============================================

# OpenAI Configuration (REQUIRED)
# Get your API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Brave Search API Configuration (REQUIRED for accurate, up-to-date comparisons)
# Get your API key from: https://api.search.brave.com/
BRAVE_API_KEY=your-brave-api-key-here

# ============================================
# Brave Search Configuration (Optional)
# ============================================

# Number of search results to fetch per item
BRAVE_SEARCH_COUNT=5

# Number of snippets to include in summary
BRAVE_SEARCH_SNIPPETS=5

# API request timeout in seconds
BRAVE_SEARCH_TIMEOUT=10

# ============================================
# Database Configuration
# ============================================

POSTGRES_USER=compair_user
POSTGRES_PASSWORD=compair_password
POSTGRES_DB=compair_db
POSTGRES_PORT=5432

# PostgreSQL data directory
# Use forward slashes on Windows (e.g., C:/data/postgresql_data)
# Relative path example: ./data/postgresql_data
POSTGRES_DATA_PATH=./data/postgresql_data

# Database connection URL (auto-constructed from above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================
# Container Configuration
# ============================================

POSTGRES_CONTAINER_NAME=compair_postgres
BACKEND_CONTAINER_NAME=compair_backend
FRONTEND_CONTAINER_NAME=compair_frontend

# ============================================
# Port Mappings
# ============================================

# PostgreSQL
POSTGRES_HOST_PORT=5432

# Backend API
BACKEND_HOST_PORT=8000
BACKEND_CONTAINER_PORT=8000

# Frontend
FRONTEND_HOST_PORT=3000
FRONTEND_CONTAINER_PORT=80

# ============================================
# Application Settings
# ============================================

# Backend configuration
BACKEND_HOST=0.0.0.0
BACKEND_RELOAD=--reload              # Remove --reload in production

# Frontend configuration
REACT_APP_API_URL=http://localhost:8000

# Docker Compose project name
COMPOSE_PROJECT_NAME=compair
